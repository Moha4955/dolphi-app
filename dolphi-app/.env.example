# ─── SUPABASE ────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── STRIPE ──────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_YOUR_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Stripe Price IDs — create these in Stripe Dashboard → Products
STRIPE_PRICE_STARTER_MONTHLY=price_STARTER_MONTHLY_ID
STRIPE_PRICE_GROWTH_MONTHLY=price_GROWTH_MONTHLY_ID
STRIPE_PRICE_BUSINESS_MONTHLY=price_BUSINESS_MONTHLY_ID
STRIPE_PRICE_AGENCY_MONTHLY=price_AGENCY_MONTHLY_ID
STRIPE_PRICE_STARTER_ANNUAL=price_STARTER_ANNUAL_ID
STRIPE_PRICE_GROWTH_ANNUAL=price_GROWTH_ANNUAL_ID
STRIPE_PRICE_BUSINESS_ANNUAL=price_BUSINESS_ANNUAL_ID
STRIPE_PRICE_AGENCY_ANNUAL=price_AGENCY_ANNUAL_ID

# ─── AI (ANTHROPIC) ──────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ─── EMAIL (RESEND) ──────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_YOUR_KEY_HERE
RESEND_FROM_EMAIL=hello@dolphi.com.au

# ─── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.dolphi.com.au
# Use http://localhost:3000 for local development
